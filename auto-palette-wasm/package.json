{
  "name": "auto-palette-wasm",
  "description": "A Wasm library for automatically extracting color palettes from an image",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/t28hub/auto-palette.git"
  },
  "bugs": {
    "url": "https://github.com/t28hub/auto-palette/issues"
  },
  "homepage": "https://github.com/t28hub/auto-palette",
  "author": {
    "name": "Tatsuya Maki",
    "url": "https://github.com/t28hub"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "clean": "rimraf dist",
    "predev": "wasm-pack build --out-name index --target web",
    "dev": "vite",
    "prebuild": "pnpm clean",
    "build": "vite build && tsc"
  },
  "keywords": [],
  "devDependencies": {
    "rimraf": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6",
    "vite": "^4.4.4",
    "vite-plugin-dts": "^3.3.1",
    "vite-plugin-wasm": "^3.2.2",
    "wasm-pack": "^0.12.1"
  },
  "packageManager": "pnpm@8.6.0"
}
