{
  "name": "auto-palette",
  "version": "0.1.0",
  "description": "A Wasm library for automatically extracting color palettes from an image",
  "license": "MIT",
  "main": "dist/index.umd.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.umd.js"
    }
  },
  "homepage": "https://github.com/t28hub/auto-palette",
  "repository": {
    "type": "git",
    "url": "https://github.com/t28hub/auto-palette.git",
    "directory": "wasm"
  },
  "bugs": {
    "url": "https://github.com/t28hub/auto-palette/issues"
  },
  "author": {
    "name": "Tatsuya Maki",
    "url": "https://github.com/t28hub"
  },
  "scripts": {
    "clean": "rimraf dist",
    "dev": "pnpm run wasm:dev & vite",
    "build": "pnpm run wasm:web && vite build && tsc",
    "wasm:dev": "wasm-pack build --out-name index --target web --dev",
    "wasm:web": "wasm-pack build --out-name index --target web --release",
    "lint": "eslint --ext .ts ./src",
    "lint:fix": "eslint --fix --ext .ts ./src"
  },
  "keywords": [],
  "devDependencies": {
    "@types/offscreencanvas": "^2019.7.0",
    "eslint": "^8.45.0",
    "rimraf": "^5.0.1",
    "vite": "^4.4.4",
    "vite-plugin-dts": "^3.3.1",
    "vite-plugin-wasm": "^3.2.2",
    "wasm-pack": "^0.12.1"
  },
  "packageManager": "pnpm@8.6.0"
}
